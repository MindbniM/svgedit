# SVGEdit 项目环境变量配置模板
# 复制此文件为 .env 并根据实际环境修改

# ========================
# Remote Bridge 配置
# ========================
# WebSocket 中继服务端口
BRIDGE_PORT=9527

# ========================
# Diagram Server 配置
# ========================
# Diagram Server HTTP API 端口
DIAGRAM_PORT=2333

# Diagram 文件存储目录（相对于 diagram-server 目录或绝对路径）
DIAGRAMS_DIR=./diagrams

# SVGEdit 编辑器 URL（用于生成编辑器链接）
# 开发环境示例
EDITOR_BASE_URL=http://localhost:8000/src/editor/index.html
# 生产环境示例
# EDITOR_BASE_URL=http://your-domain.com/svgedit/src/editor/index.html

# ========================
# SVGEdit 前端配置
# ========================
# Vite 开发服务器端口
VITE_PORT=8000

# Vite 开发服务器主机
VITE_HOST=localhost

# ========================
# 生产环境配置
# ========================
# Node 环境
NODE_ENV=development
# NODE_ENV=production

# Node.js 二进制路径（用于 systemd 服务）
NODE_BIN=/usr/bin/node
