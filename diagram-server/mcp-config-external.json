{
  "mcpServers": {
    "svgedit-diagram": {
      "type": "stdio",
      "command": "node",
      "args": [
        "./mcp-server.js"
      ],
      "env": {
        "DIAGRAM_SERVER_URL": "http://your-domain.com/svgedit/mcp",
        "DIAGRAM_WS_URL": "ws://your-domain.com/svgedit/mcp/ws"
      },
      "timeout": 60
    }
  }
}
